class Solution {
public:
    int maxSubArray(vector<int>& nums) {
       // int pre_sum = nums[0];
       int n = nums.size();
       if(n==1){
        return nums[0];
       }
        int max_sum = INT_MIN;
        int cur_sum = 0;


        for(int i=0; i<nums.size(); i++){
            cur_sum = cur_sum + nums[i];
            max_sum = max(max_sum, cur_sum);
            
            if (cur_sum < 0){
                cur_sum = 0;
            }
        }
        return max_sum;
    }
};
